# GENZ WhatsApp Backend — copy to .env and fill in real values
PORT=5000
NODE_ENV=development

# Database (local Docker or MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/tm-whatsapp

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRES_IN=30d

# URLs (production must use HTTPS)
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:5000

# Security
ADMIN_BOOTSTRAP_TOKEN=change-me-admin-bootstrap-token-32chars-min
BACKUP_ENCRYPTION_KEY=change-me-backup-encryption-key-32chars
MESSAGE_ENCRYPTION_SECRET=change-me-message-encryption-secret-32
ALLOW_ANONYMOUS_DEVICE_AUTH=false
ALLOW_SOCKET_WITHOUT_AUTH=false
ALLOW_MOCK_PAYMENTS=true

# Media — Cloudinary (optional in dev; uses local uploads/ if unset)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional in dev)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Push notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# WebRTC TURN (recommended for production calls behind NAT)
TURN_SERVER_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# Redis (optional — multi-instance socket scaling)
REDIS_URL=

# Payments (optional)
ALLOW_REAL_PAYMENT_PROVIDERS=false
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_WEBHOOK_SECRET=
