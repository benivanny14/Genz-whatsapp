# ══════════════════════════════════════════════════
# GENZ WhatsApp Backend — copy to .env and fill in
# ══════════════════════════════════════════════════

# ── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/genz-whatsapp
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/genz-whatsapp

# ── Auth (generate strong random strings!) ───────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret

# ── Admin (owner-only) Security ──────────────────────────────
# COMPLETELY SEPARATE secret from JWT_SECRET above — never reuse it.
ADMIN_JWT_SECRET=change-me-to-a-third-long-random-secret-owner-only
# Secret, hard-to-guess base path for the admin login gateway.
# Only you should know this URL. Example: /api/x7f2-owner-gate-9k
ADMIN_BASE_PATH=/api/x7f2-owner-gate-9k
# Optional: comma-separated list of IPs allowed to reach the admin gateway
# at all (e.g. your home/office static IP or VPN exit IP). Leave empty to
# disable this extra layer (2FA + JWT still fully apply either way).
ADMIN_IP_ALLOWLIST=

JWT_EXPIRE=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── URLs ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:5000

# ── Security ─────────────────────────────────────
ADMIN_BOOTSTRAP_TOKEN=change-me-admin-bootstrap-token-32chars-min
BACKUP_ENCRYPTION_KEY=change-me-backup-encryption-key-32chars
MESSAGE_ENCRYPTION_SECRET=change-me-message-encryption-secret-32
ALLOW_ANONYMOUS_DEVICE_AUTH=false
ALLOW_SOCKET_WITHOUT_AUTH=false
ALLOW_MOCK_PAYMENTS=true

# ── Media — Cloudinary (optional; uses local uploads/ if unset) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Redis (optional; enables scaling, caching, rate limit) ───────
REDIS_URL=
# Redis Cloud: redis://user:pass@host:port

# ── Email / OTP (optional in dev) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@genz-whatsapp.com

# ── SMS OTP (Africa's Talking or Twilio) ─────────
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Push Notifications (Web Push VAPID) ──────────
# Generate: node scripts/generate-vapid.js
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ── Firebase FCM (optional alternative to VAPID) ─
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Payments ─────────────────────────────────────
# M-Pesa (Kenya/Tanzania)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=

# Airtel Money
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=

# Halopesa
HALOPESA_API_KEY=
HALOPESA_MERCHANT_ID=

# ── AI Features (optional) ───────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── WebRTC TURN Server (for production video calls) ──
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=
