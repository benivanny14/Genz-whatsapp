# ── MongoDB Configuration ───────────────────────────────────────────────────────
# Use MongoDB Atlas for production (recommended)
# Format: mongodb+srv://user:pass@cluster.mongodb.net/genz-whatsapp
MONGODB_URI=mongodb://localhost:27017/tm-whatsapp
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=0

# ── Redis Configuration (Optional - for distributed socket architecture) ─────────
# Use Redis Cloud for production
REDIS_URL=redis://localhost:6379

# ── Application URLs ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:5000

# ── Authentication (generate strong random strings!) ─────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Admin Configuration ─────────────────────────────────────────────────────────
ADMIN_BOOTSTRAP_TOKEN=change-me-to-a-random-admin-bootstrap-token

# ── Encryption Keys ─────────────────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=change-me-to-a-32-character-encryption-key
MESSAGE_ENCRYPTION_SECRET=change-me-to-a-32-character-encryption-secret

# ── Email Configuration (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@genz-whatsapp.com

# ── Cloudinary Configuration (REQUIRED for production media storage) ────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Firebase Configuration (for push notifications) ────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# ── Sentry Configuration (for error tracking) ─────────────────────────────────
SENTRY_DSN=your-sentry-dsn
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── M-Pesa Configuration (Tanzania) ──────────────────────────────────────────────
MPESA_ENVIRONMENT=sandbox
MPESA_API_KEY=your-mpesa-api-key
MPESA_PUBLIC_KEY=your-mpesa-public-key
MPESA_SERVICE_PROVIDER_CODE=000000
MPESA_WEBHOOK_SECRET=your-mpesa-webhook-secret
MPESA_IP_WHITELIST=

# ── Airtel Money Configuration ───────────────────────────────────────────────────
AIRTEL_ENVIRONMENT=sandbox
AIRTEL_CLIENT_ID=your-airtel-client-id
AIRTEL_CLIENT_SECRET=your-airtel-client-secret
AIRTEL_COUNTRY=TZ
AIRTEL_CURRENCY=TZS
AIRTEL_WEBHOOK_SECRET=your-airtel-webhook-secret
AIRTEL_IP_WHITELIST=

# ── Yas Payment Configuration ───────────────────────────────────────────────────
YAS_API_KEY=your-yas-api-key
YAS_MERCHANT_ID=your-yas-merchant-id
YAS_SECRET_KEY=your-yas-secret-key
YAS_WEBHOOK_SECRET=your-yas-webhook-secret
YAS_IP_WHITELIST=

# ── Halopesa Configuration ─────────────────────────────────────────────────────
HALOPESA_API_KEY=your-halopesa-api-key
HALOPESA_MERCHANT_ID=your-halopesa-merchant-id
HALOPESA_SECRET_KEY=your-halopesa-secret-key
HALOPESA_WEBHOOK_SECRET=your-halopesa-webhook-secret
HALOPESA_IP_WHITELIST=

# ── Stripe Configuration (for card payments) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── WebRTC Configuration (for voice/video calls) ───────────────────────────────
# Metered TURN Server (recommended for production)
METERED_TURN_USERNAME=your-metered-turn-username
METERED_TURN_PASSWORD=your-metered-turn-password

# Alternative TURN Server Configuration (if not using Metered)
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_SERVER_URL_TCP=turn:your-turn-server.com:443?transport=tcp
TURN_SERVER_URL_TLS=turns:your-turn-server.com:443
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-credential
ICE_TRANSPORT_POLICY=all
ICE_CANDIDATE_POOL_SIZE=10
BUNDLE_POLICY=balanced
RTCP_MUX_POLICY=require
ICE_CONNECTION_TIMEOUT=5000
ICE_GATHERING_TIMEOUT=3000

# ── Webhook Configuration ───────────────────────────────────────────────────────
WEBHOOK_IP_WHITELIST=

# ── Feature Flags ───────────────────────────────────────────────────────────────
ALLOW_ANONYMOUS_DEVICE_AUTH=false
ALLOW_MOCK_PAYMENTS=false
ALLOW_REAL_PAYMENT_PROVIDERS=false
ALLOW_DEVICE_ADMIN=false

# ── Development Settings ────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
MAX_UPLOAD_BYTES=104857600

# ── Frontend Environment Variables ───────────────────────────────────────────────
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000
VITE_REQUIRE_AUTH=true
VITE_ENABLE_DEMO_DATA=false
VITE_ENABLE_DEV_SERVICE_WORKER=false

# ── Frontend WebRTC Configuration ────────────────────────────────────────────────
# Metered TURN Server (recommended for production)
VITE_METERED_TURN_USERNAME=your-metered-turn-username
VITE_METERED_TURN_PASSWORD=your-metered-turn-password

# Alternative TURN Server Configuration (if not using Metered)
VITE_TURN_SERVER_URL=turn:your-turn-server.com:3478
VITE_TURN_SERVER_URL_TCP=turn:your-turn-server.com:443?transport=tcp
VITE_TURN_SERVER_URL_TLS=turns:your-turn-server.com:443
VITE_TURN_USERNAME=your-turn-username
VITE_TURN_CREDENTIAL=your-turn-credential
