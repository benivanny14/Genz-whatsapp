# ══════════════════════════════════════════════════
# GENZ WhatsApp Frontend — copy to .env.local
# ══════════════════════════════════════════════════

# ── API & Socket ─────────────────────────────────
# Local development
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Must match backend ADMIN_BASE_PATH exactly (including /api prefix)
VITE_ADMIN_BASE_PATH=/api/x7f2-owner-gate-9k


# Production (replace with your actual backend URL)
# VITE_API_URL=https://your-backend.yourdomain.com/api
# VITE_SOCKET_URL=https://your-backend.yourdomain.com

# ── Auth ─────────────────────────────────────────
VITE_REQUIRE_AUTH=true
VITE_ENABLE_DEMO_DATA=false

# ── Push Notifications (VAPID) ────────────────────
# Generate with: node backend/scripts/generate-vapid.js
# Must match backend VAPID_PUBLIC_KEY
VITE_VAPID_PUBLIC_KEY=

# ── Firebase Cloud Messaging (optional) ──────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ── WebRTC (TURN servers for production calls) ────
# Leave empty to use Google STUN only (works for same-network calls)
# For production calls across networks, get free TURN from metered.ca
VITE_TURN_SERVER_URL=
VITE_TURN_SERVER_URL_TCP=
VITE_TURN_SERVER_URL_TLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
